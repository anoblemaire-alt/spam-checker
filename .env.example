# ─── Hiya API ───────────────────────────────────────────────
# Mode d'authentification : "apikey" ou "oauth2"
HIYA_AUTH_MODE=apikey

# Mode apikey : coller la clé fournie par Hiya
HIYA_API_KEY=

# Mode oauth2 : renseigner les 3 valeurs ci-dessous
HIYA_CLIENT_ID=
HIYA_CLIENT_SECRET=
HIYA_TOKEN_URL=

# ─── Serveur ────────────────────────────────────────────────
PORT=3001

# ─── Cache (optionnel) ──────────────────────────────────────
# Durée du cache en secondes (défaut : 3600 = 1h)
CACHE_TTL=3600
